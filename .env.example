# WhatsApp Agent SaaS - Environment Configuration
# Copy this to .env and update

# Application
APP_NAME="WhatsApp Agent SaaS"
APP_URL=http://localhost:3000

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=demo123

# Database
DATABASE_URL=postgresql://whatsapp:whatsapp123@postgres:5432/whatsappdb
POSTGRES_DB=whatsappdb
POSTGRES_USER=whatsapp
POSTGRES_PASSWORD=whatsapp123

# AI / Ollama
OLLAMA_BASE_URL=http://ollama:11434
# Change model here: qwen2.5:7b-instruct | llama3.1:8b | mistral:7b
OLLAMA_MODEL=qwen2.5:7b-instruct
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024

# Evolution API (WhatsApp) - Optional for real WhatsApp
# Get Evolution API at: https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=my-business

# Business Profile (used by AI)
BUSINESS_NAME="My Business"
BUSINESS_PHONE=+966500000000
BUSINESS_HOURS="Sunday-Thursday 9AM-6PM AST"
BUSINESS_TYPE=retail
BUSINESS_LANGUAGE=en

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="WhatsApp Agent SaaS"

# Features
ENABLE_REAL_WHATSAPP=false
ENABLE_MOCK_SIMULATOR=true
AUTO_REPLY_ENABLED=true
LEAD_CAPTURE_ENABLED=true
